class Solution {
    public boolean isAnagram(String s, String t) {
        // 1. Length check: if they don't match, they can't be anagrams
        if (s.length() != t.length()) {
            return false;
        }

        // 2. Initialize frequency array for 26 lowercase English letters
        int[] count = new int[26];

        // 3. Increment for characters in 's', decrement for characters in 't'
        for (int i = 0; i < s.length(); i++) {
            count[s.charAt(i) - 'a']++;
            count[t.charAt(i) - 'a']--;
        }

        // 4. If any index is non-zero, it's not a valid anagram
        for (int val : count) {
            if (val != 0) {
                return false;
            }
        }

        return true;
    }
}
